{
	"printWidth": 120,
	"singleQuote": true,
	"useTabs": true,
	"semi": true,
	"bracketSpacing": true,
	"trailingComma": "all",
	"tabWidth": 2,
	"bracketSameLine": false,
	"endOfLine": "lf",
	"overrides": [
		{
			"files": "*.md",
			"options": {
				"singleQuote": false,
				"quoteProps": "preserve"
			}
		}
	]
}
