{
  "name": "jdcharts",
  "version": "1.0.0",
  "description": "Canvas charting: pass normalized OHLC (`ChartData`) via chart.setData().",
  "repository": {
    "type": "git",
    "url": "https://github.com/ljdcodes/jdcharts.git"
  },
  "homepage": "https://github.com/ljdcodes/jdcharts#readme",
  "bugs": {
    "url": "https://github.com/ljdcodes/jdcharts/issues"
  },
  "type": "module",
  "main": "./dist/lib/jdcharts.js",
  "types": "./dist/lib/jdcharts.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/jdcharts.d.ts",
      "import": "./dist/lib/jdcharts.js",
      "default": "./dist/lib/jdcharts.js"
    }
  },
  "files": [
    "dist/lib",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "preview": "npx --yes serve . -p 5173",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "James David",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
